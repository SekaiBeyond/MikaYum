rules_version = '2';

// MikaYum Firestore security rules.
// Strategy:
//   - menuItems / categories / config: public read so anonymous customers can browse.
//   - tables: public read (so a customer can land on /t/:id and see status);
//     direct writes restricted to admin. Cloud Functions (openTableSession,
//     markTablePaid, placeOrder) update via the Admin SDK and bypass these rules.
//   - sessions: read by staff/kitchen/admin OR by anonymous customers whose uid
//     is in customerUids. All writes through Cloud Functions only.
//   - orders: created via placeOrder; status changes via updateOrderStatus.
//     Direct client writes denied. Reads: customer sees own orders only;
//     staff/kitchen/admin see all (needed for kitchen board + staff table view).
//   - users: admin-only writes; users can read their own row (for sign-out UX).
//   - counters / reports: callable / admin-only.
//
// Audit pass scheduled for M5. If you add new collections, deny by default.

service cloud.firestore {
    match /databases/{database}/documents {

        function isSignedIn() {
            return request.auth != null;
        }

        function role() {
            return request.auth != null ? request.auth.token.role : null;
        }

        function isStaff() {
            return role() in ['staff', 'kitchen', 'admin'];
        }

        function isAdmin() {
            return role() == 'admin';
        }

        // -------------------- public-readable reference data --------------------
        match /menuItems/{itemId} {
            allow read: if true;
            allow write: if isAdmin();
        }

        match /categories/{categoryId} {
            allow read: if true;
            allow write: if isAdmin();
        }

        match /config/{docId} {
            allow read: if true;
            allow write: if isAdmin();
        }

        // -------------------- tables --------------------
        match /tables/{tableId} {
            // Customers always reach a table by ID (the QR-scan deep link), so
            // `get` is public, but `list` is staff-only — no enumeration of all
            // tables and their unpaid totals from a customer device.
            allow get: if true;
            allow list: if isStaff();
            // Direct writes blocked — Cloud Functions update via admin SDK.
            allow write: if isAdmin();
        }

        // -------------------- sessions --------------------
        match /sessions/{sessionId} {
            allow read: if isStaff()
                || (isSignedIn() && request.auth.uid in resource.data.customerUids);
            allow write: if false; // Cloud Functions only.
        }

        // -------------------- orders --------------------
        match /orders/{orderId} {
            // Customer can read (get OR list) only orders they placed. The list
            // query in useCustomerOrders filters where('placedByUid','==',uid),
            // which keeps every returned doc inside the rule, so list succeeds.
            allow get, list: if isStaff()
                || (isSignedIn()
                    && resource.data.placedByUid == request.auth.uid);
            // Direct create/update/delete blocked — callable functions handle these.
            allow write: if false;
        }

        // -------------------- counters (order numbering) --------------------
        match /counters/{day} {
            allow read, write: if false; // Cloud Functions only.
        }

        // -------------------- users (staff) --------------------
        match /users/{uid} {
            allow get: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
            allow list, write: if isAdmin();
        }

        // -------------------- reports --------------------
        match /reports/{day} {
            allow read: if isAdmin();
            allow write: if false;
        }

        // Default deny.
        match /{document=**} {
            allow read, write: if false;
        }
    }
}
